{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "sldr skeleton input schema",
  "description": "JSON schema for creating presentation skeletons via sldr CLI",
  "type": "object",
  "properties": {
    "description": {
      "description": "Optional description",
      "type": [
        "string",
        "null"
      ],
      "default": null
    },
    "flavor": {
      "description": "Flavor to use (e.g., \"acme\", \"default\")",
      "type": [
        "string",
        "null"
      ],
      "default": null
    },
    "name": {
      "description": "Name of the skeleton (used as filename)",
      "type": "string"
    },
    "slides": {
      "description": "List of slide references (paths relative to slides directory)",
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "slidev_config": {
      "description": "Rendering configuration",
      "anyOf": [
        {
          "$ref": "#/$defs/RenderOpts"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "title": {
      "description": "Title for the presentation",
      "type": "string"
    }
  },
  "required": [
    "name",
    "title",
    "slides"
  ],
  "$defs": {
    "RenderOpts": {
      "description": "Presentation rendering configuration\n\nSerialized as `slidev_config` for backwards compatibility with existing\nskeleton.toml files. Controls transition style, aspect ratio, and other\nrendering options for the self-contained HTML output.",
      "type": "object",
      "properties": {
        "aspect_ratio": {
          "description": "Aspect ratio hint for PDF/PPTX export viewport (e.g., \"16/9\", \"4/3\").\nThe HTML output is fully responsive and fills the browser viewport.",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "canvas_width": {
          "description": "Canvas width hint in pixels for export (informational)",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "default": null,
          "minimum": 0
        },
        "dark_mode": {
          "description": "Start in dark mode",
          "type": [
            "boolean",
            "null"
          ],
          "default": null
        },
        "drawings": {
          "description": "Enable/disable drawing feature (reserved for future use)",
          "type": [
            "boolean",
            "null"
          ],
          "default": null
        },
        "record": {
          "description": "Enable slide recording (reserved for future use)",
          "type": [
            "boolean",
            "null"
          ],
          "default": null
        },
        "theme": {
          "description": "Theme name (reserved for future use)",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "title": {
          "description": "Title override for the presentation",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "transition": {
          "description": "Transition effect between slides: \"fade\", \"slide-left\", \"slide-right\", \"none\"",
          "type": [
            "string",
            "null"
          ],
          "default": null
        }
      }
    }
  }
}